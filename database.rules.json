{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        },
        "partnerName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        },
        "inviteCode": {
          ".validate": "newData.isString() && newData.val().length >= 6 && newData.val().length <= 20"
        },
        "partnerId": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "email": {
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length > 0 && newData.val().length <= 254)"
        },
        "emailCaptured": {
          ".validate": "newData.isBoolean()"
        }
      }
    },
    "inviteCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && newData.child('uid').val() === auth.uid && (data.val() === null || data.child('uid').val() === auth.uid)",
        "uid": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "expiresAt": {
          ".validate": "newData.isNumber() && newData.val() > now && newData.val() <= now + 900001"
        }
      }
    },
    "pushTokens": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('couples').child(auth.uid).child('partnerId').val() === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.isString() && newData.val().beginsWith('ExponentPushToken[')"
      }
    },
    "couples": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "sessions": {
      "$coupleId": {
        ".read": "auth != null && ($coupleId.beginsWith(auth.uid + '_') || $coupleId.endsWith('_' + auth.uid))",
        ".write": "auth != null && ($coupleId.beginsWith(auth.uid + '_') || $coupleId.endsWith('_' + auth.uid))",
        "$date": {
          "partner1": {
            "timestamp": {
              ".validate": "newData.isNumber() && newData.val() <= now + 5000 && newData.val() >= now - 86400000"
            }
          },
          "partner2": {
            "timestamp": {
              ".validate": "!newData.exists() || (newData.isNumber() && newData.val() <= now + 5000 && newData.val() >= now - 86400000)"
            }
          },
          "paused": {
            ".validate": "newData.isBoolean()"
          },
          "meditationEnded": {
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        }
      }
    }
  }
}
